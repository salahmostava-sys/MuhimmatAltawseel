# ─── Sentry (Error Monitoring) ───
# Optional: Sentry DSN for error tracking and session replay
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=

# ─── Supabase (مشروع سحابي — Production على Vercel) ───
# انسخ هذا الملف إلى .env.local للتطوير. على Vercel: Settings → Environment Variables
#
# يجب أن يكون الرابط على شكل https://xxxxxxxx.supabase.co (ليس localhost)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# ─── Monitoring (Production Debugging) ───
# Optional: when set, frontend logger sends error/warn events to this HTTP endpoint.
# Example: https://logs.example.com/frontend-events
#
# Security: the URL is embedded in the client bundle — protect the collector with auth,
# rate limits, and CORS; do not expose a writable endpoint to the whole internet.
VITE_MONITORING_ENDPOINT=

# ─── E2E (Playwright) — اختياري ───
# الافتراضي: http://127.0.0.1:5000 (نفس منفذ Vite في vite.config.ts)
# E2E_BASE_URL=http://127.0.0.1:5000
# لتشغيل اختبار «لوحة التحكم بعد تسجيل الدخول» (يُتخطّى بدون هذه القيم):
# E2E_ASSERT_AUTHENTICATED_DASHBOARD=1
# E2E_DASHBOARD_EMAIL=
# E2E_DASHBOARD_PASSWORD=

# ─── Groq AI ───
# GROQ_API_KEY must be added as a Supabase Edge Function secret, NOT here.
# In Supabase Dashboard: Settings → Edge Functions → Add secret: GROQ_API_KEY

# ─── AI Backend (FastAPI) — يُمرَّر عبر بروكسي Vite (/ai → localhost:8000) ───
# نفس القيمة في ai-backend/.env كـ AI_INTERNAL_KEY لتفعيل التحقق من X-Internal-Key
# AI_INTERNAL_KEY=
# VITE_AI_BACKEND_URL=http://localhost:8000
